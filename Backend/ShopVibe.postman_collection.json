{
  "info": {
    "_postman_id": "shopvibe-backend-collection",
    "name": "ShopVibe Backend API",
    "description": "Complete API collection for ShopVibe eCommerce backend.\n\n**Setup:**\n1. Import this collection\n2. Import `ShopVibe.postman_environment.json`\n3. Select the `ShopVibe Local` environment\n4. Set `token` variable after login via Firebase\n\n**Auth:**\nAll protected routes need an `Authorization: Bearer {{token}}` header.\nGet your token from Firebase Auth (client SDK) or Firebase Console.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "🔍 General",
      "item": [
        {
          "name": "Root — API Info",
          "request": {~
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5000",
              "path": [
                ""
              ]
            },
            "description": "Returns API info and a list of all available endpoints."
          },
          "response": []
        },
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            },
            "description": "Check if the server is running."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🔑 Auth",
      "description": "Authentication endpoints. Login/Signup is handled client-side by Firebase SDK. Use `register` to create a Firestore profile after signup.",
      "item": [
        {
          "name": "Register User Profile",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"uid\": \"FIREBASE_UID_HERE\",\n  \"name\": \"Alex Mercer\",\n  \"email\": \"alex@shopvibe.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            },
            "description": "Call this AFTER Firebase client-side signup. Pass the Firebase UID, name, and email to create a Firestore user profile."
          },
          "response": []
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "Firebase ID Token"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            },
            "description": "Get the authenticated user's Firestore profile."
          },
          "response": []
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Alex Mercer Updated\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            },
            "description": "Update the authenticated user's display name."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📦 Products",
      "description": "Product CRUD. GET endpoints are public. POST/PUT/DELETE require admin role.",
      "item": [
        {
          "name": "Get All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=12",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1",
                  "description": "Page number (default: 1)"
                },
                {
                  "key": "limit",
                  "value": "12",
                  "description": "Items per page (default: 12, max: 100)"
                },
                {
                  "key": "search",
                  "value": "",
                  "description": "Search by title or description",
                  "disabled": true
                },
                {
                  "key": "category",
                  "value": "",
                  "description": "Filter by category",
                  "disabled": true
                }
              ]
            },
            "description": "List all products. Supports pagination, full-text search, and category filtering.\n\n**Examples:**\n- `?search=watch` — search products\n- `?category=fashion` — filter by category\n- `?page=2&limit=6` — paginate"
          },
          "response": []
        },
        {
          "name": "Get All Products — With Search",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?search=watch&limit=5",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "watch"
                },
                {
                  "key": "limit",
                  "value": "5"
                }
              ]
            },
            "description": "Search products by keyword in title or description."
          },
          "response": []
        },
        {
          "name": "Get All Products — By Category",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?category=fashion",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ],
              "query": [
                {
                  "key": "category",
                  "value": "fashion"
                }
              ]
            },
            "description": "Filter products by a specific category."
          },
          "response": []
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/categories",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "categories"
              ]
            },
            "description": "Returns all unique product categories stored in Firestore."
          },
          "response": []
        },
        {
          "name": "Get Single Product",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            },
            "description": "Get a single product by its Firestore document ID. Set `productId` in your environment."
          },
          "response": []
        },
        {
          "name": "Create Product (Admin Only)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}",
                "description": "Must be an admin token"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Premium Chronograph Quartz Watch\",\n  \"price\": 129.99,\n  \"description\": \"Elegant chronograph quartz wristwatch with a premium brown leather strap.\",\n  \"category\": \"fashion\",\n  \"image\": \"https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500\",\n  \"rating\": {\n    \"rate\": 4.8,\n    \"count\": 184\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            },
            "description": "Create a new product. Requires admin role. Set `role: admin` in your Firestore users collection first."
          },
          "response": []
        },
        {
          "name": "Update Product (Admin Only)",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 99.99,\n  \"title\": \"Updated Watch Title\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            },
            "description": "Update any fields of an existing product. Requires admin role."
          },
          "response": []
        },
        {
          "name": "Delete Product (Admin Only)",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            },
            "description": "Permanently delete a product. Requires admin role."
          },
          "response": []
        }
      ]
    },
    {
      "name": "🛒 Cart",
      "description": "Cart management. All routes require a valid Firebase token.",
      "item": [
        {
          "name": "Get Cart",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart"
              ]
            },
            "description": "Get the authenticated user's full cart with all items."
          },
          "response": []
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"title\": \"Premium Chronograph Quartz Watch\",\n  \"price\": 129.99,\n  \"image\": \"https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500\",\n  \"quantity\": 1\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart"
              ]
            },
            "description": "Add a product to the cart. If the product already exists in the cart, its quantity is incremented."
          },
          "response": []
        },
        {
          "name": "Update Item Quantity",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"quantity\": 3\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/cart/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart",
                "{{productId}}"
              ]
            },
            "description": "Update the quantity of a specific item. Use the productId as the URL param. Setting quantity to 0 removes the item."
          },
          "response": []
        },
        {
          "name": "Remove Item from Cart",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart",
                "{{productId}}"
              ]
            },
            "description": "Remove a specific item from the cart using its productId."
          },
          "response": []
        },
        {
          "name": "Clear Entire Cart",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/cart",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "cart"
              ]
            },
            "description": "Remove ALL items from the cart at once."
          },
          "response": []
        }
      ]
    },
    {
      "name": "📋 Orders",
      "description": "Order placement and history. All routes require a valid Firebase token.",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"fullName\": \"Alex Mercer\",\n    \"email\": \"alex@shopvibe.com\",\n    \"address\": \"123 Main Street\",\n    \"city\": \"Seattle\",\n    \"state\": \"WA\",\n    \"zipCode\": \"98101\",\n    \"phone\": \"2065551234\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Place an order using items currently in the user's Firestore cart.\n\n**Important:** Add items to the cart first using POST /api/cart.\n\nThis automatically:\n- Calculates subtotal, 8% tax, and shipping (free over $75)\n- Creates an order document in Firestore\n- Clears the user's cart"
          },
          "response": []
        },
        {
          "name": "Get My Orders",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            },
            "description": "Get the full order history for the authenticated user, sorted by most recent."
          },
          "response": []
        },
        {
          "name": "Get Single Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}"
              ]
            },
            "description": "Get a single order by its Firestore document ID. Returns 403 if the order doesn't belong to the authenticated user."
          },
          "response": []
        }
      ]
    },
    {
      "name": "❤️ Wishlist",
      "description": "Wishlist management. All routes require a valid Firebase token.",
      "item": [
        {
          "name": "Get Wishlist",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/wishlist",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wishlist"
              ]
            },
            "description": "Get all products in the authenticated user's wishlist."
          },
          "response": []
        },
        {
          "name": "Toggle Wishlist Item",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"title\": \"Premium Chronograph Quartz Watch\",\n  \"price\": 129.99,\n  \"image\": \"https://images.unsplash.com/photo-1523275335684-37898b6baf30?w=500\",\n  \"category\": \"fashion\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/wishlist",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wishlist"
              ]
            },
            "description": "Toggle a product in the wishlist:\n- If the product is NOT in the wishlist → adds it\n- If the product IS already in the wishlist → removes it\n\nThe response includes an `action` field: `added` or `removed`."
          },
          "response": []
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/wishlist/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "wishlist",
                "{{productId}}"
              ]
            },
            "description": "Directly remove a specific product from the wishlist by productId."
          },
          "response": []
        }
      ]
    }
  ]
}